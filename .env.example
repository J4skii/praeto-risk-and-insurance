# Praeto Risk & Insurance — marketing site environment template
# Copy to .env.local for development. NEVER commit real keys.
# Build: Vite (loadEnv). Deploy: Firebase Hosting (project "praeto-web").

# Google Gemini key — powers the AI features; vite.config.ts maps GEMINI_API_KEY
# into process.env.API_KEY + process.env.GEMINI_API_KEY at build time.
GEMINI_API_KEY=

# Endpoint the "Get a Tailored Quote" form POSTs to (App.tsx). Leave blank to
# disable/submit-to-nowhere in local dev.
VITE_QUOTE_ENDPOINT=

# NOTE: the Compliance Club link is a hardcoded constant, not an env var —
# see constants.ts COMPLIANCE_CLUB_URL (currently https://compliance-club.vercel.app).
